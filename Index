                </div>
                <div className="bar">
                  <div className="bar-fill" style={{ width: `${(cnt/topIssues[0][1])*100}%`, background: getIssueColor(key) }} />
                </div>
              </div>
            ))}
          </div>

          <div style={{ fontSize: 10, color: "#475569", textTransform: "uppercase", letterSpacing: "1.5px", marginBottom: 8 }}>
            {view === "rep" ? `Reps (${repStats.length})` : `Stores (${storeStats.length})`}
          </div>

          {view === "rep" ? repStats.map(r => (
            <div key={r.rep} className={`rep-item ${selectedRep === r.rep ? "active" : ""}`}
              onClick={() => { setSelectedRep(r.rep); setExpandedIssue(null); }}>
              <div style={{ fontSize: 12, fontWeight: 500, color: selectedRep === r.rep ? "#a5b4fc" : "#cbd5e1" }}>{r.rep}</div>
              <div style={{ fontSize: 10, color: "#475569", marginTop: 2 }}>{r.store} · <span style={{ color: "#f97316" }}>{r.allRows.length} exceptions</span></div>
            </div>
          )) : storeStats.map(s => (
            <div key={s.store} className={`rep-item ${selectedStore === s.store ? "active" : ""}`}
              onClick={() => { setSelectedStore(s.store); setExpandedIssue(null); }}>
              <div style={{ fontSize: 12, fontWeight: 500, color: selectedStore === s.store ? "#a5b4fc" : "#cbd5e1" }}>{s.store}</div>
              <div style={{ fontSize: 10, color: "#475569", marginTop: 2 }}><span style={{ color: "#f97316" }}>{s.allRows.length} exceptions</span> · {s.reps.size} reps</div>
            </div>
          ))}
        </div>

        {/* Main content */}
        <div style={{ flex: 1, overflowY: "auto", padding: "24px 28px" }}>
          {!selected ? (
            <div style={{ display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", height: "100%", color: "#334155" }}>
              <div style={{ fontFamily: "'Syne', sans-serif", fontSize: 40, fontWeight: 800, marginBottom: 12, color: "#1e2030" }}>SELECT A {view === "rep" ? "REP" : "STORE"}</div>
              <div style={{ fontSize: 13, letterSpacing: "1px" }}>Choose from the list to view detailed exceptions</div>
            </div>
          ) : (
            <div>
              {/* Header */}
              <div style={{ marginBottom: 24 }}>
                <div style={{ fontFamily: "'Syne', sans-serif", fontSize: 28, fontWeight: 800, color: "#fff" }}>
                  {view === "rep" ? selected.rep : selected.store}
                </div>
                <div style={{ fontSize: 12, color: "#475569", marginTop: 4 }}>
                  {view === "rep"
                    ? `Store: ${selected.store} · ${selected.allRows.length} total exception lines · ${Object.keys(selected.issues).length} issue types`
                    : `${selected.allRows.length} total exception lines · ${selected.reps.size} reps · ${Object.keys(selected.issues).length} issue types`
                  }
                </div>
              </div>

              {/* Summary badges */}
              <div style={{ display: "flex", flexWrap: "wrap", gap: 8, marginBottom: 24 }}>
                {Object.entries(selected.issues).sort((a,b) => b[1].count - a[1].count).map(([key, data]) => (
                  <div key={key} className="issue-badge" style={{
                    color: getIssueColor(key),
                    background: getIssueBg(key),
                    borderColor: getIssueBorder(key),
                    fontSize: 11, padding: "4px 10px", borderRadius: 20
                  }}>
                    {key} <strong>×{data.count}</strong>
                  </div>
                ))}
              </div>

              {/* Issue cards */}
              {Object.entries(selected.issues).sort((a,b) => b[1].count - a[1].count).map(([key, data]) => {
                const info = ISSUE_INFO[key];
                const isOpen = expandedIssue === key;
                const uniqueCustomers = [...data.customerIds];
                const uniqueWOs = [...data.workOrders];

                return (
                  <div key={key} className="issue-card"
                    style={{ background: getIssueBg(key), borderColor: getIssueBorder(key) }}
                    onClick={() => setExpandedIssue(isOpen ? null : key)}>
                    <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between" }}>
                      <div style={{ display: "flex", alignItems: "center", gap: 12 }}>
                        <div style={{
                          width: 36, height: 36, borderRadius: 8, background: getIssueColor(key),
                          display: "flex", alignItems: "center", justifyContent: "center",
                          color: "#fff", fontWeight: 700, fontSize: 14, flexShrink: 0
                        }}>
                          {data.count}
                        </div>
                        <div>
                          <div style={{ fontSize: 13, fontWeight: 500, color: getIssueColor(key) }}>{key}</div>
                          <div style={{ fontSize: 11, color: "#64748b", marginTop: 1 }}>
                            {uniqueCustomers.length} account{uniqueCustomers.length !== 1 ? "s" : ""} · {uniqueWOs.length} work order{uniqueWOs.length !== 1 ? "s" : ""}
                          </div>
                        </div>
                      </div>
                      <div style={{ color: "#94a3b8", fontSize: 16 }}>{isOpen ? "▲" : "▼"}</div>
                    </div>

                    {isOpen && (
                      <div style={{ marginTop: 14, paddingTop: 14, borderTop: `1px solid ${getIssueBorder(key)}` }}>
                        {/* Explanation */}
                        <div style={{
                          background: "rgba(0,0,0,0.08)", borderRadius: 8, padding: "10px 14px",
                          fontSize: 12, lineHeight: 1.6, color: "#475569", marginBottom: 14
                        }}>
                          <strong style={{ color: getIssueColor(key) }}>What this means:</strong> {info?.description || "See report for details."}
                        </div>

                        {/* Accounts */}
                        <div style={{ marginBottom: 10 }}>
                          <div style={{ fontSize: 10, color: "#64748b", textTransform: "uppercase", letterSpacing: "1.5px", marginBottom: 6 }}>
                            Affected Customer IDs ({uniqueCustomers.length})
                          </div>
                          <div>
                            {uniqueCustomers.map(id => (
                              <span key={id} className="account-tag">{id}</span>
                            ))}
                          </div>
                        </div>

                        {/* Work orders */}
                        <div>
                          <div style={{ fontSize: 10, color: "#64748b", textTransform: "uppercase", letterSpacing: "1.5px", marginBottom: 6 }}>
                            Work Orders ({uniqueWOs.length})
                          </div>
                          <div>
                            {uniqueWOs.map(wo => (
                              <span key={wo} className="account-tag">{wo}</span>
                            ))}
                          </div>
                        </div>

                        {/* Instance breakdown if store view - show per rep */}
                        {view === "store" && (() => {
                          const repBreakdown = {};
                          selected.allRows.filter(r => getIssueKey(r) === key && r.rep).forEach(r => {
                            repBreakdown[r.rep] = (repBreakdown[r.rep] || 0) + 1;
                          });
                          const entries = Object.entries(repBreakdown).sort((a,b) => b[1]-a[1]);
                          if (!entries.length) return null;
                          return (
                            <div style={{ marginTop: 12 }}>
                              <div style={{ fontSize: 10, color: "#64748b", textTransform: "uppercase", letterSpacing: "1.5px", marginBottom: 6 }}>By Rep</div>
                              <div style={{ display: "flex", flexWrap: "wrap", gap: 6 }}>
                                {entries.map(([rep, cnt]) => (
                                  <span key={rep} style={{
                                    background: "rgba(0,0,0,0.1)", border: `1px solid ${getIssueBorder(key)}`,
                                    borderRadius: 6, padding: "2px 8px", fontSize: 11, color: getIssueColor(key)
                                  }}>
                                    {rep} <strong>×{cnt}</strong>
                                  </span>
                                ))}
                              </div>
                            </div>
                          );
                        })()}
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
