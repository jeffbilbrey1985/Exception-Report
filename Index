function getIssueKey(row) {
  if (row.type === "Risk Assurance") return "Risk Assurance";
  return row.subType || row.type;
}

function getIssueColor(key) {
  return ISSUE_INFO[key]?.color || "#64748b";
}

function getIssueBg(key) {
  return ISSUE_INFO[key]?.bg || "#f8fafc";
}

function getIssueBorder(key) {
  return ISSUE_INFO[key]?.border || "#cbd5e1";
}

