  const [expandedIssue, setExpandedIssue] = useState(null);

  const filteredData = useMemo(() => RAW_DATA.filter(d => d.rep && d.rep.trim() !== ""), []);

  const repStats = useMemo(() => {
    const map = {};
    filteredData.forEach(row => {
      const rep = row.rep;
      if (!map[rep]) map[rep] = { rep, store: row.store, issues: {}, allRows: [] };
      map[rep].allRows.push(row);
      const key = getIssueKey(row);
      if (!map[rep].issues[key]) map[rep].issues[key] = { count: 0, customerIds: new Set(), workOrders: new Set() };
      map[rep].issues[key].count++;
      map[rep].issues[key].customerIds.add(row.customerId);
      map[rep].issues[key].workOrders.add(row.workOrder);
    });
    return Object.values(map).sort((a, b) => b.allRows.length - a.allRows.length);
  }, [filteredData]);

  const storeStats = useMemo(() => {
    const map = {};
    RAW_DATA.forEach(row => {
      const store = row.store;
      if (!map[store]) map[store] = { store, issues: {}, allRows: [], reps: new Set() };
      map[store].allRows.push(row);
      if (row.rep) map[store].reps.add(row.rep);
      const key = getIssueKey(row);
      if (!map[store].issues[key]) map[store].issues[key] = { count: 0, customerIds: new Set(), workOrders: new Set() };
      map[store].issues[key].count++;
      map[store].issues[key].customerIds.add(row.customerId);
      map[store].issues[key].workOrders.add(row.workOrder);
    });
    return Object.values(map).sort((a, b) => b.allRows.length - a.allRows.length);
  }, []);

  const selected = view === "rep"
    ? repStats.find(r => r.rep === selectedRep)
    : storeStats.find(s => s.store === selectedStore);

  const totalExceptions = filteredData.length;
  const totalReps = repStats.length;
